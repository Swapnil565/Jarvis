### JARVIS Production .env Example
# Copy to .env or use your secrets manager to populate these in production.

# Environment
JARVIS_ENV=production

# Secrets
SECRET_KEY=replace_with_strong_random_value

# Database (Postgres recommended for production)
# Example: postgresql://user:password@host:5432/jarvis_prod
DATABASE_URL=postgresql://jarvis_user:strongpassword@db.example.com:5432/jarvis_prod

# Redis (managed/secure Redis endpoint)
REDIS_URL=rediss://:redis_password@redis-cluster.example.com:6379/0

# Celery broker/result URLs (if not set, will use REDIS_URL)
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# API
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# Logging
LOG_LEVEL=INFO
LOG_DIR=/var/log/jarvis

# Celery tuning
CELERY_WORKER_CONCURRENCY=4
CELERY_PREFETCH_MULTIPLIER=2
CELERY_MAX_TASKS_PER_CHILD=1000
