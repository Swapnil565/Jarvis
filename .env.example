# =============================================================================
# JARVIS 3.0 - ENVIRONMENT VARIABLES (TEMPLATE)
# =============================================================================
# IMPORTANT: Copy this file to .env and fill in your actual values
# NEVER commit .env to Git! It's already in .gitignore
# =============================================================================

# ===========================================================================
# DATABASE CONFIGURATION (Supabase PostgreSQL)
# ===========================================================================
# Production (Supabase)
DATABASE_URL=postgresql://postgres.ulnfnxvxlswjomqrobrd:YOUR_DB_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# Transaction Pooler (recommended for connection pooling)
DATABASE_URL_POOLED=postgresql://postgres.ulnfnxvxlswjomqrobrd:YOUR_DB_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres

# Local Development (if using local PostgreSQL)
# DATABASE_URL=postgresql://jarvis:your_password@localhost:5432/jarvis

# ===========================================================================
# REDIS CONFIGURATION
# ===========================================================================
# Local Development
REDIS_URL=redis://localhost:6379/0

# Production (Render/Upstash)
# REDIS_URL=redis://default:password@hostname:port

# ===========================================================================
# CELERY CONFIGURATION
# ===========================================================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Worker Configuration
CELERY_WORKER_CONCURRENCY=4
CELERY_PREFETCH_MULTIPLIER=2
CELERY_MAX_TASKS_PER_CHILD=1000

# ===========================================================================
# SECURITY & AUTHENTICATION
# ===========================================================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-min-32-characters-CHANGE-THIS
JWT_SECRET_KEY=your-jwt-secret-key-min-32-characters-CHANGE-THIS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===========================================================================
# AI API KEYS
# ===========================================================================
# Cerebras (Fast inference)
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Groq (Fast LLaMA)
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter (Multiple models)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# HuggingFace
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HF_TOKEN=your_huggingface_token_here

# OpenAI (if using)
# OPENAI_API_KEY=sk-your-openai-api-key-here

# ===========================================================================
# APPLICATION CONFIGURATION
# ===========================================================================
JARVIS_ENV=development
# Options: development, production, staging

LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

DEBUG=false
# Set to true only in development

APP_NAME=JARVIS 3.0
VERSION=3.0.0

# ===========================================================================
# CORS CONFIGURATION
# ===========================================================================
# Frontend URLs (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://jarvis.vercel.app

# ===========================================================================
# MONITORING (Optional)
# ===========================================================================
# Sentry for error tracking
# SENTRY_DSN=https://your-sentry-dsn-here

# ===========================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ===========================================================================
# Before deploying to production:
# 1. Generate new SECRET_KEY and JWT_SECRET_KEY (min 32 characters)
# 2. Set JARVIS_ENV=production
# 3. Set DEBUG=false
# 4. Update DATABASE_URL to production database
# 5. Update REDIS_URL to production Redis
# 6. Add all required AI API keys
# 7. Update ALLOWED_ORIGINS with production frontend URL
# 8. Never commit .env to Git!
# ===========================================================================
